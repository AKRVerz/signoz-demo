# OTLP endpoint SigNoz (HTTP, port 4318).
# Untuk SigNoz DRC / environment tim, ganti host sesuai URL yang diberikan.
# Contoh lokal: http://host.docker.internal:4318
# Contoh DRC:     http://signoz-drc.example.com:4318
OTEL_EXPORTER_OTLP_ENDPOINT=http://host.docker.internal:4318

# Environment label di SigNoz (muncul sebagai tag deployment.environment)
OTEL_DEPLOYMENT_ENVIRONMENT=demo
